Lønnsummer kommune etter arbeidsted

require no.ssb.fdb:53 as fdb 
create-dataset jobbbdata

//Sett startår 
let år = 2025
let dato_år = $år ++ "-11-30"

//legger til arbeidsted
import fdb/ARBLONN_ARB_ARBKOMM $dato_år as arbeidsted ++ $år
generate fylke ++ $år = substr(arbeidsted ++ $år,1,2)
generate kommnr ++ $år = substr(arbeidsted++ $år ,1,4)

keep if fylke ++ $år == '50'

import fdb/ARBLONN_LONN_KONTANT_INNRAPP $dato_år as lønn ++ $år
summarize lønn ++ $år

tabulate arbeidsted ++ $år , summarize(lønn ++ $år) mean sum freq flatten


